<UserControl
    x:Class="ArchiveMaster.Views.AiChatPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="using:ArchiveMaster.Behaviors"
    xmlns:cvt="clr-namespace:ArchiveMaster.Converters;assembly=ArchiveMaster.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="using:ArchiveMaster.Enums"
    xmlns:ic="using:FluentIcons.Avalonia.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ArchiveMaster.ViewModels;assembly=ArchiveMaster.Core"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ItemsControl ItemsSource="{Binding $parent[UserControl].Conversation.Messages}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Panel>
                    <!--  用户  -->
                    <Border
                        Background="{DynamicResource Background2}"
                        IsVisible="{Binding Sender, Converter={x:Static cvt:Converters.EqualWithParameter}, ConverterParameter=User}">
                        <SelectableTextBlock
                            b:TextBlockInlinesBehavior.ItemsSource="{Binding Inlines}"
                            TextWrapping="Wrap" />
                    </Border>

                    <!--  系统  -->
                    <Border IsVisible="{Binding Sender, Converter={x:Static cvt:Converters.EqualWithParameter}, ConverterParameter=System}">
                        <SelectableTextBlock
                            b:TextBlockInlinesBehavior.ItemsSource="{Binding Inlines}"
                            TextWrapping="Wrap" />
                    </Border>

                    <!--  AI  -->
                    <Border IsVisible="{Binding Sender, Converter={x:Static cvt:Converters.EqualWithParameter}, ConverterParameter=Assistant}">
                        <SelectableTextBlock
                            b:TextBlockInlinesBehavior.ItemsSource="{Binding Inlines}"
                            TextWrapping="Wrap" />
                    </Border>
                </Panel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>