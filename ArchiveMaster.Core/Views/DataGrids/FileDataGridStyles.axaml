<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="using:FzLib.Avalonia.Controls"
    xmlns:cvt="using:ArchiveMaster.Converters"
    xmlns:fs="clr-namespace:ArchiveMaster.ViewModels.FileSystem"
    xmlns:ic="using:FluentIcons.Avalonia"
    xmlns:icm="using:FluentIcons.Avalonia.Markup"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:v="using:ArchiveMaster.Views"
    xmlns:vm="clr-namespace:ArchiveMaster.ViewModels">
    <SolidColorBrush
        x:Key="DataGridCellFocusVisualPrimaryBrush"
        Color="Transparent" />
    <SolidColorBrush
        x:Key="DataGridCellFocusVisualSecondaryBrush"
        Color="Transparent" />
    <Thickness x:Key="FileDataGridRowDetailPopupPadding">8,8,8,8</Thickness>
    <system:Double x:Key="FileDataGridRowDetailPopupSpacing">8</system:Double>
    <system:Double x:Key="FileDataGridRowDetailLabelWidth">80</system:Double>

    <ControlTheme
        x:Key="{x:Type v:FileDataGridRowDetailDefaultContent}"
        TargetType="v:FileDataGridRowDetailDefaultContent">
        <Setter Property="ContentTemplate">
            <DataTemplate>
                <StackPanel Spacing="{StaticResource FileDataGridRowDetailPopupSpacing}">
                    <ctrl:FormItem
                        Classes="BoldLabel"
                        Label="路径："
                        LabelWidth="{StaticResource FileDataGridRowDetailLabelWidth}">
                        <Grid ColumnDefinitions="*,8,Auto,8,Auto">
                            <Grid.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Height" Value="20" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </Grid.Styles>
                            <Button
                                Grid.Column="2"
                                Classes="Link"
                                Command="{Binding Source={x:Static vm:GlobalCommands.Instance}, Path=OpenFileCommand}"
                                CommandParameter="{Binding Path}"
                                IsVisible="{Binding Path, Converter={x:Static cvt:Converters.IsNotNull}}">
                                <ic:FluentIcon
                                    Height="16"
                                    Icon="Document" />
                            </Button>
                            <Button
                                Grid.Column="4"
                                Classes="Link"
                                Command="{Binding Source={x:Static vm:GlobalCommands.Instance}, Path=OpenParentDirCommand}"
                                CommandParameter="{Binding Path}"
                                IsVisible="{Binding Path, Converter={x:Static cvt:Converters.IsNotNull}}">
                                <ic:FluentIcon
                                    Height="16"
                                    Icon="FolderOpen" />
                            </Button>
                            <SelectableTextBlock
                                Inlines="{Binding ., Converter={x:Static v:FileDataGridRowDetailConverters.FilePathToInlineConverter}}"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </ctrl:FormItem>
                    <ctrl:FormItem
                        Classes="BoldLabel"
                        Label="元数据："
                        LabelWidth="{StaticResource FileDataGridRowDetailLabelWidth}">
                        <SelectableTextBlock
                            Inlines="{Binding ., Converter={x:Static v:FileDataGridRowDetailConverters.FileMetadataToInlineConverter}}"
                            TextTrimming="CharacterEllipsis" />
                    </ctrl:FormItem>
                    <ctrl:FormItem
                        Classes="BoldLabel"
                        IsVisible="{Binding Message, Converter={x:Static cvt:Converters.IsNotNull}}"
                        Label="信息："
                        LabelWidth="{StaticResource FileDataGridRowDetailLabelWidth}">
                        <SelectableTextBlock
                            Text="{Binding Message}"
                            TextWrapping="Wrap"
                            ToolTip.Tip="{Binding Message}" />
                    </ctrl:FormItem>
                </StackPanel>
            </DataTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme
        x:Key="{x:Type v:SimpleFileDataGrid}"
        BasedOn="{StaticResource {x:Type DataGrid}}"
        TargetType="v:SimpleFileDataGrid">
        <Setter Property="RowDetailsPopupTemplate">
            <DataTemplate>
                <v:FileDataGridRowDetailDefaultContent Content="{Binding .}" />
            </DataTemplate>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid RowDefinitions="*,8,Auto">
                    <Border
                        x:Name="DataGridBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid
                            ClipToBounds="True"
                            ColumnDefinitions="Auto,*,Auto"
                            RowDefinitions="Auto,*,Auto,Auto">
                            <DataGridColumnHeader
                                Name="PART_TopLeftCornerHeader"
                                Theme="{StaticResource DataGridTopLeftColumnHeader}" />
                            <DataGridColumnHeadersPresenter
                                Name="PART_ColumnHeadersPresenter"
                                Grid.Row="0"
                                Grid.Column="1"
                                Grid.ColumnSpan="2" />
                            <Rectangle
                                Name="PART_ColumnHeadersAndRowsSeparator"
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Height="1"
                                VerticalAlignment="Bottom"
                                Fill="{DynamicResource DataGridGridLinesBrush}" />

                            <DataGridRowsPresenter
                                Name="PART_RowsPresenter"
                                Grid.Row="1"
                                Grid.Column="0"
                                ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}">
                                <DataGridRowsPresenter.GestureRecognizers>
                                    <ScrollGestureRecognizer
                                        CanHorizontallyScroll="True"
                                        CanVerticallyScroll="True"
                                        IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_RowsPresenter}" />
                                </DataGridRowsPresenter.GestureRecognizers>
                            </DataGridRowsPresenter>
                            <Rectangle
                                Name="PART_BottomRightCorner"
                                Grid.Row="2"
                                Grid.Column="2"
                                Fill="{DynamicResource DataGridScrollBarsSeparatorBackground}" />
                            <ScrollBar
                                Name="PART_VerticalScrollbar"
                                Grid.Row="1"
                                Grid.Column="2"
                                Width="{DynamicResource ScrollBarSize}"
                                Orientation="Vertical" />

                            <Grid
                                Grid.Row="2"
                                Grid.Column="1"
                                ColumnDefinitions="Auto,*">
                                <Rectangle Name="PART_FrozenColumnScrollBarSpacer" />
                                <ScrollBar
                                    Name="PART_HorizontalScrollbar"
                                    Grid.Column="1"
                                    Height="{DynamicResource ScrollBarSize}"
                                    Orientation="Horizontal" />
                            </Grid>
                            <Border
                                x:Name="PART_DisabledVisualElement"
                                Grid.Row="0"
                                Grid.RowSpan="4"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{DynamicResource DataGridDisabledVisualElementBackground}"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                IsVisible="{Binding !$parent[DataGrid].IsEnabled}" />
                        </Grid>

                    </Border>
                    <Grid
                        Grid.Row="2"
                        Margin="4"
                        ColumnDefinitions="Auto,0,Auto,16,*">
                        <StackPanel
                            x:Name="PART_DataGridButtons"
                            Margin="0,0,8,0"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                x:Name="PART_SelectAllButton"
                                Classes="Icon"
                                Content="{icm:FluentIcon Icon=SelectAllOn}"
                                ToolTip.Tip="全选" />
                            <Button
                                x:Name="PART_SelectNoneButton"
                                Classes="Icon"
                                Content="{icm:FluentIcon Icon=SelectAllOff}"
                                ToolTip.Tip="全不选" />
                            <Button
                                x:Name="PART_SwitchSelectionButton"
                                Classes="Icon"
                                Content="{icm:FluentIcon Icon=CopySelect}"
                                ToolTip.Tip="反选" />
                            <ToggleButton
                                x:Name="PART_ProcessCheckedOnlyButton"
                                Classes="Icon"
                                Content="{icm:FluentIcon Icon=Multiselect}"
                                ToolTip.Tip="仅处理选中的行" />
                            <Button
                                x:Name="PART_SearchButton"
                                Classes="Icon"
                                Content="{icm:FluentIcon Icon=Search}"
                                ToolTip.Tip="搜索">
                                <Button.Flyout>
                                    <Flyout>
                                        <Grid ColumnDefinitions="200,8,Auto">
                                            <TextBox />
                                            <Button
                                                Grid.Column="2"
                                                Classes="Icon"
                                                Content="{icm:FluentIcon Icon=Search}"
                                                ToolTip.Tip="搜索" />
                                        </Grid>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button
                                x:Name="PART_FilterButton"
                                Classes="Icon"
                                Content="{icm:FluentIcon Icon=Filter}"
                                ToolTip.Tip="筛选">
                                <Button.Flyout>
                                    <Flyout>
                                        <Grid RowDefinitions="Auto,8,Auto">
                                            <v:FileFilterPanel />
                                            <Button
                                                Grid.Row="2"
                                                HorizontalAlignment="Right"
                                                Content="筛选" />
                                        </Grid>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                        <ContentControl
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            IsVisible="{Binding $parent[DataGrid].ShowCount}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <TextBlock
                                    IsVisible="{Binding $parent[DataGrid].ItemsSource, Converter={x:Static cvt:Converters.IsNotNull}}"
                                    Text="{Binding $parent[DataGrid].ItemsSource.Count, StringFormat='共 {0} 项'}"
                                    ToolTip.Tip="{Binding $parent[DataGrid].ItemsSource.Count, StringFormat='共 {0} 项'}" />
                            </StackPanel>
                        </ContentControl>
                        <ContentControl
                            Grid.Column="4"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Footer}" />
                    </Grid>

                    <Popup
                        x:Name="PART_Popup"
                        Grid.RowSpan="3"
                        Placement="BottomEdgeAlignedLeft"
                        PlacementTarget="{Binding ElementName=DataGridBorder}">
                        <Border Padding="6">
                            <Border
                                x:Name="PART_PopupBorder"
                                Padding="{StaticResource FileDataGridRowDetailPopupPadding}"
                                Background="{DynamicResource Background3}"
                                BoxShadow="0 0 6 0 #88000000"
                                CornerRadius="8">
                                <Grid ColumnDefinitions="*,8,Auto">
                                    <ContentControl
                                        Content="{TemplateBinding SelectedItem}"
                                        ContentTemplate="{TemplateBinding RowDetailsPopupTemplate}" />
                                    <Button
                                        x:Name="PART_ClosePopupButton"
                                        Grid.Column="2"
                                        Width="12"
                                        Height="12"
                                        Padding="0"
                                        VerticalAlignment="Top"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Classes="Icon">
                                        <Path
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Data="M 0 0 L 8 8 M 0 8 L 8 0"
                                            Stroke="{DynamicResource Foreground0}"
                                            StrokeThickness="1" />
                                    </Button>
                                </Grid>
                            </Border>
                        </Border>
                    </Popup>

                </Grid>
            </ControlTemplate>
        </Setter>
        <Setter Property="SelectedItem" Value="{Binding SelectedFile}" />


    </ControlTheme>

    <ControlTheme
        x:Key="{x:Type v:TreeFileDataGrid}"
        BasedOn="{StaticResource {x:Type v:SimpleFileDataGrid}}"
        TargetType="v:TreeFileDataGrid">
        <Setter Property="Template">
            <ControlTemplate>

                <Grid RowDefinitions="*,0,Auto">
                    <Border
                        x:Name="DataGridBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid
                            ClipToBounds="True"
                            ColumnDefinitions="Auto,*,Auto"
                            RowDefinitions="Auto,*,Auto,Auto">
                            <DataGridColumnHeader
                                Name="PART_TopLeftCornerHeader"
                                Theme="{StaticResource DataGridTopLeftColumnHeader}" />
                            <DataGridColumnHeadersPresenter
                                Name="PART_ColumnHeadersPresenter"
                                Grid.Row="0"
                                Grid.Column="1"
                                Grid.ColumnSpan="2" />
                            <Rectangle
                                Name="PART_ColumnHeadersAndRowsSeparator"
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Height="1"
                                VerticalAlignment="Bottom"
                                Fill="{DynamicResource DataGridGridLinesBrush}" />

                            <DataGridRowsPresenter
                                Name="PART_RowsPresenter"
                                Grid.Row="1"
                                Grid.Column="0"
                                ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}">
                                <DataGridRowsPresenter.GestureRecognizers>
                                    <ScrollGestureRecognizer
                                        CanHorizontallyScroll="True"
                                        CanVerticallyScroll="True"
                                        IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_RowsPresenter}" />
                                </DataGridRowsPresenter.GestureRecognizers>
                            </DataGridRowsPresenter>
                            <Rectangle
                                Name="PART_BottomRightCorner"
                                Grid.Row="2"
                                Grid.Column="2"
                                Fill="{DynamicResource DataGridScrollBarsSeparatorBackground}" />
                            <ScrollBar
                                Name="PART_VerticalScrollbar"
                                Grid.Row="1"
                                Grid.Column="2"
                                Width="{DynamicResource ScrollBarSize}"
                                Orientation="Vertical" />

                            <Grid
                                Grid.Row="2"
                                Grid.Column="1"
                                ColumnDefinitions="Auto,*">
                                <Rectangle Name="PART_FrozenColumnScrollBarSpacer" />
                                <ScrollBar
                                    Name="PART_HorizontalScrollbar"
                                    Grid.Column="1"
                                    Height="{DynamicResource ScrollBarSize}"
                                    Orientation="Horizontal" />
                            </Grid>
                            <Border
                                x:Name="PART_DisabledVisualElement"
                                Grid.Row="0"
                                Grid.RowSpan="4"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{DynamicResource DataGridDisabledVisualElementBackground}"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                IsVisible="{Binding !$parent[DataGrid].IsEnabled}" />
                        </Grid>

                    </Border>
                    <Grid
                        Grid.Row="2"
                        Margin="4"
                        ColumnDefinitions="Auto,16,*">

                        <ContentControl
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            IsVisible="{Binding $parent[DataGrid].ShowCount}">
                            <TextBlock
                                IsVisible="{Binding $parent[DataGrid].ItemsSource, Converter={x:Static cvt:Converters.IsNotNull}}"
                                Text="{Binding $parent[DataGrid].ItemsSource, Converter={x:Static cvt:TreeFileDataGridStatisticsConverter.Instance}}" />
                        </ContentControl>
                        <ContentControl
                            Grid.Column="2"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Footer}" />
                    </Grid>


                    <Popup
                        x:Name="PART_Popup"
                        Grid.RowSpan="3"
                        Placement="BottomEdgeAlignedLeft">
                        <Border Padding="6">
                            <Border
                                x:Name="PART_PopupBorder"
                                Padding="{StaticResource FileDataGridRowDetailPopupPadding}"
                                Background="{DynamicResource Background3}"
                                BoxShadow="0 0 6 0 #88000000"
                                CornerRadius="8">
                                <ContentControl
                                    Content="{TemplateBinding SelectedItem}"
                                    ContentTemplate="{TemplateBinding RowDetailsPopupTemplate}" />
                            </Border>
                        </Border>
                    </Popup>
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>