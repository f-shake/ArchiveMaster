<v:VerticalTwoStepPanelBase
    x:Class="ArchiveMaster.Views.PhotoTagManagerPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ct="using:FzLib.Avalonia.Controls"
    xmlns:cvt="using:ArchiveMaster.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="clr-namespace:ArchiveMaster.Enums"
    xmlns:ic="clr-namespace:FluentIcons.Avalonia.Markup;assembly=FluentIcons.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ne="clr-namespace:FzLib.Avalonia.MarkupExtensions;assembly=FzLib.Avalonia"
    xmlns:v="using:ArchiveMaster.Views"
    xmlns:vm="using:ArchiveMaster.ViewModels"
    xmlns:vmfs="clr-namespace:ArchiveMaster.ViewModels.FileSystem"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ExecuteButtonContent="加载"
    mc:Ignorable="d">
    <v:VerticalTwoStepPanelBase.ConfigsContent>
        <ct:StackFormItemGroup>
            <ct:FormItem Label="根目录：">
                <v:FilePickerTextBox
                    FileNames="{Binding Config.RootDir}"
                    Filter="{Binding Config.Filter}"
                    IsFilterBarVisible="True"
                    Type="OpenFolder" />
            </ct:FormItem>
            <ct:FormItem
                Grid.Row="2"
                Label="标签数据库文件：">
                <v:FilePickerTextBox
                    FileNames="{Binding Config.TagFile}"
                    StringFileTypeFilter="ArchiveMaster Photo Tags（图像标签库）文件;*.ampt;;"
                    Type="OpenFile" />
            </ct:FormItem>
        </ct:StackFormItemGroup>
    </v:VerticalTwoStepPanelBase.ConfigsContent>
    <v:VerticalTwoStepPanelBase.ResultsContent>
        <Grid RowDefinitions="2*,8,*">
            <v:TreeFileDataGrid
                ColumnIsCheckedIndex="-1"
                ItemsSource="{Binding TreeFiles}"
                SelectedItem="{Binding SelectedFile}">
                <v:TreeFileDataGrid.Columns>
                    <DataGridTextColumn
                        Binding="{Binding Tag.Count, FallbackValue=' ', StringFormat='{}{0}个标签'}"
                        Header="标签"
                        IsReadOnly="True" />
                </v:TreeFileDataGrid.Columns>
            </v:TreeFileDataGrid>
            <ScrollViewer
                Grid.Row="2"
                Padding="0,0,20,0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static cvt:Converters.AndLogic}">
                            <Binding
                                Converter="{x:Static cvt:Converters.IsNotNull}"
                                Path="SelectedTags" />
                            <Binding
                                Converter="{x:Static cvt:Converters.InverseBool}"
                                Path="SelectedFile.IsDir" />
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <StackPanel.Styles>
                        <Style Selector="ct|StringListEditor">
                            <Setter Property="AddButtonPosition" Value="Right" />
                            <Setter Property="Layout" Value="HorizontalStack" />
                        </Style>
                        <Style Selector="ct|FormItem /template/ ContentPresenter#PART_Header">
                            <Setter Property="FontWeight" Value="Bold" />
                        </Style>
                    </StackPanel.Styles>
                    <ct:FormItem Header="对象">
                        <ct:StringListEditor ItemsSource="{Binding SelectedTags.ObjectTags}" />
                    </ct:FormItem>
                    <ct:FormItem Header="场景">
                        <ct:StringListEditor ItemsSource="{Binding SelectedTags.SceneTags}" />
                    </ct:FormItem>
                    <ct:FormItem Header="情绪">
                        <ct:StringListEditor ItemsSource="{Binding SelectedTags.MoodTags}" />
                    </ct:FormItem>
                    <ct:FormItem Header="颜色">
                        <ct:StringListEditor ItemsSource="{Binding SelectedTags.ColorTags}" />
                    </ct:FormItem>
                    <ct:FormItem Header="拍摄">
                        <ct:StringListEditor ItemsSource="{Binding SelectedTags.TechniqueTags}" />
                    </ct:FormItem>
                    <ct:FormItem Header="文字">
                        <ct:StringListEditor ItemsSource="{Binding SelectedTags.TextTags}" />
                    </ct:FormItem>
                    <ct:FormItem Header="描述">
                        <TextBox
                            Text="{Binding SelectedTags.Description}"
                            TextWrapping="Wrap" />
                    </ct:FormItem>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </v:VerticalTwoStepPanelBase.ResultsContent>
</v:VerticalTwoStepPanelBase>