<v:TwoStepPanelBase
    x:Class="ArchiveMaster.Views.FileFilterOperationPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ct="using:FzLib.Avalonia.Controls"
    xmlns:cvt="using:ArchiveMaster.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:e="using:ArchiveMaster.Enums"
    xmlns:io="using:FzLib.IO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:me="using:FzLib.Avalonia.MarkupExtensions"
    xmlns:v="using:ArchiveMaster.Views"
    xmlns:vm="clr-namespace:ArchiveMaster.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:TwinFileCleanerViewModel"
    mc:Ignorable="d">
    <v:TwoStepPanelBase.Resources>
        <cvt:FileLengthConverter x:Key="FileLengthConverter" />
        <cvt:LenientDateTimeConverter x:Key="LenientDateTimeConverter" />
    </v:TwoStepPanelBase.Resources>
    <v:TwoStepPanelBase.ConfigsContent>
        <ct:StackFormItemGroup>
            <ct:FormItem Label="源目录：">
                <v:FilePickerTextBox
                    AllowMultiple="True"
                    FileNames="{Binding Config.SourceDirs}"
                    Type="OpenFolder" />
            </ct:FormItem>

            <ct:FormItem Label="目标目录：">
                <v:FilePickerTextBox
                    FileNames="{Binding Config.TargetDir}"
                    Type="OpenFolder" />
            </ct:FormItem>

            <ct:FormItem Label="名称路径筛选：">
                <v:FileFilterBar Filter="{Binding Config.PathFilter}" />
            </ct:FormItem>


            <ct:FormItem Label="时间/大小筛选：">
                <Grid ColumnDefinitions="3*,8,Auto,8,3*,16,2*,8,Auto,8,2*">
                    <TextBox
                        Text="{Binding Config.EarliestTime, Converter={StaticResource LenientDateTimeConverter}, UpdateSourceTrigger=LostFocus}"
                        TextAlignment="Center" />
                    <TextBlock
                        Grid.Column="2"
                        Text="——" />
                    <TextBox
                        Grid.Column="4"
                        Text="{Binding Config.LatestTime, Converter={StaticResource LenientDateTimeConverter}, UpdateSourceTrigger=LostFocus}"
                        TextAlignment="Center" />

                    <TextBox
                        Grid.Column="6"
                        Text="{Binding Config.MinLength, Converter={StaticResource FileLengthConverter}, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                        TextAlignment="Center" />
                    <TextBlock
                        Grid.Column="8"
                        Text="——" />
                    <TextBox
                        Grid.Column="10"
                        Text="{Binding Config.MaxLength, Converter={StaticResource FileLengthConverter}, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                        TextAlignment="Center" />
                </Grid>
            </ct:FormItem>

            <ct:FormItem Label="选项：">
                <ct:WrapFormItemGroup>
                    <ct:FormItem Header="文件操作类型">
                        <ct:RadioButtonGroup
                            DisplayMemberBinding="{Binding ., Converter={x:Static cvt:Converters.Description}}"
                            ItemsSource="{me:EnumValues e:FileFilterOperationType}"
                            SelectedItem="{Binding Config.Type}" />
                    </ct:FormItem>
                    <ct:FormItem
                        Header="Hash类型"
                        IsVisible="{Binding Config.Type, Converter={x:Static cvt:Converters.EqualWithParameter}, ConverterParameter=Hash}">
                        <ct:RadioButtonGroup
                            DisplayMemberBinding="{Binding ., Converter={x:Static cvt:Converters.Description}}"
                            ItemsSource="{me:EnumValues io:HashAlgorithmType}"
                            SelectedItem="{Binding Config.HashType}" />
                    </ct:FormItem>
                    <ct:FormItem Header="目标文件">
                        <ComboBox
                            x:Name="ccbTarget"
                            Width="280"
                            DisplayMemberBinding="{Binding ., Converter={x:Static cvt:Converters.Description}}"
                            ItemsSource="{me:EnumValues e:FileFilterOperationTargetFileNameMode}"
                            SelectedItem="{Binding Config.TargetFileNameMode}" />
                        <ct:FormItem.Description>
                            <Panel>
                                <TextBlock
                                    MaxWidth="360"
                                    IsVisible="{Binding #ccbTarget.SelectedIndex, Converter={x:Static cvt:Converters.EqualWithParameter}, ConverterParameter=0}"
                                    Text="将文件复制/移动到目标目录时，完全保留原始目录层级结构，且文件名不变"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    MaxWidth="360"
                                    IsVisible="{Binding #ccbTarget.SelectedIndex, Converter={x:Static cvt:Converters.EqualWithParameter}, ConverterParameter=1}"
                                    Text="将文件复制/移动到目标目录时，忽略原始目录结构（所有文件直接放在目标根目录），但保留原文件名"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    MaxWidth="360"
                                    IsVisible="{Binding #ccbTarget.SelectedIndex, Converter={x:Static cvt:Converters.EqualWithParameter}, ConverterParameter=2}"
                                    Text="将文件复制/移动到目标目录时，忽略原始目录结构，但将原始相对路径信息编码到新文件名中，避免冲突"
                                    TextWrapping="Wrap" />
                            </Panel>
                        </ct:FormItem.Description>
                    </ct:FormItem>

                </ct:WrapFormItemGroup>
            </ct:FormItem>
        </ct:StackFormItemGroup>
    </v:TwoStepPanelBase.ConfigsContent>
    <v:TwoStepPanelBase.ResultsContent>
        <Grid RowDefinitions="*,8,Auto">
            <v:SimpleFileDataGrid
                ColumnLengthIndex="1.1"
                ColumnTimeIndex="1.2"
                ItemsSource="{Binding Files}">
                <v:SimpleFileDataGrid.Columns>
                    <DataGridTextColumn
                        Binding="{Binding TargetPath}"
                        Header="目标位置" />
                </v:SimpleFileDataGrid.Columns>
            </v:SimpleFileDataGrid>
        </Grid>
    </v:TwoStepPanelBase.ResultsContent>
</v:TwoStepPanelBase>